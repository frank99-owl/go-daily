# Copy to .env.local and fill in your own key.
# Never commit .env.local — it's gitignored by default.

# Required for AI coach. The app works without it, but the coach panel
# will show "service unavailable".
DEEPSEEK_API_KEY=

# Xiaomi MiMo solution-note generation (server/local batch script only).
# MIMO_API_KEY is secret. Keep it in .env.local and never prefix with NEXT_PUBLIC_.
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_MODEL=MiMo-V2.5-Pro
# Optional: defaults to mimo-api when MIMO_API_KEY is present, otherwise gemini-cli.
# SOLUTION_NOTE_PROVIDER=mimo-api
# Optional: raise/lower after smoke tests.
# SOLUTION_NOTE_MAX_CONCURRENCY=24
# SOLUTION_NOTE_API_TIMEOUT_MS=180000
# SOLUTION_NOTE_MAX_TOKENS=4096

# Optional: set your canonical production origin.
# Defaults to https://go-daily.app when unset.
# NEXT_PUBLIC_SITE_URL=https://example.com

# ---------------------------------------------------------------------------
# PostHog (Phase 1: product analytics)
# ---------------------------------------------------------------------------
# Project API key — safe to expose in browser (write-only, no read access).
NEXT_PUBLIC_POSTHOG_KEY=
# Ingest host — US Cloud: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# Sentry (Phase 1: error tracking)
# ---------------------------------------------------------------------------
# DSN — safe to expose in browser (write-only error ingest endpoint).
NEXT_PUBLIC_SENTRY_DSN=

# AI Coach model (optional, defaults to deepseek-chat).
# Any OpenAI-compatible model identifier can be used here.
# COACH_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Auth UI switches
# ---------------------------------------------------------------------------
# Email magic-link login UI toggle. The backend route is wired, but the UI
# stays hidden until a reliable SMTP (Resend) is configured. Flip to "true"
# after Resend is live to show the email field + "Send magic link" button
# on /login and in the homepage login reminder.
NEXT_PUBLIC_ENABLE_EMAIL_LOGIN=false

# Admin access (server-only). Comma-separated emails allowed to access /admin.
# ADMIN_EMAILS=admin@example.com
# 6-digit PIN required after admin email verification.
# ADMIN_PIN=123456

# Upstash Redis configuration for persistent rate limiting (optional).
# If both are provided, the app uses UpstashRateLimiter instead of
# the in-process MemoryRateLimiter, enabling cross-instance rate limiting.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Rate limit config (optional, defaults to 60s window / 10 req max).
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=10

# Server-only secret used to sign short-lived puzzle reveal tokens.
# Generate with: openssl rand -base64 32
PUZZLE_REVEAL_SECRET=

# ---------------------------------------------------------------------------
# Resend email (Phase 2: transactional + daily reminder emails)
# ---------------------------------------------------------------------------
# Server-only API key. Configure a verified sending domain in Resend first.
RESEND_API_KEY=
# Verified sender used for welcome, daily puzzle, and payment-failed emails.
EMAIL_FROM="go-daily <hello@go-daily.app>"
# Optional reply-to address.
# EMAIL_REPLY_TO=support@go-daily.app
# Vercel Cron protection for /api/cron/daily-email.
# CRON_SECRET=
# Optional batch size for each daily email cron invocation.
# EMAIL_CRON_BATCH_SIZE=50

# ---------------------------------------------------------------------------
# Supabase (Phase 1: account + cross-device sync)
# ---------------------------------------------------------------------------
# Project URL — safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (new format: sb_publishable_...) — safe in browser when RLS
# is on. Legacy anon JWT also works here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key (new format: sb_secret_...) — server-only, bypasses RLS.
# NEVER prefix with NEXT_PUBLIC_. Used by webhook handlers and trusted
# route handlers only.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe (Phase 2: subscriptions + entitlements)
# ---------------------------------------------------------------------------
# Server-only secret key. NEVER prefix with NEXT_PUBLIC_.
STRIPE_SECRET_KEY=
# Webhook signing secret from Stripe Dashboard / CLI.
STRIPE_WEBHOOK_SECRET=
# Price IDs created in Stripe Dashboard. Keep price IDs server-side and start
# Checkout from our own route handler.
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
# Planned card trial length. Keep this in sync with Stripe Dashboard copy.
STRIPE_TRIAL_DAYS=7
