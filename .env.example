# Copy to .env.local and fill in your own key.
# Never commit .env.local — it's gitignored by default.
DEEPSEEK_API_KEY=

# Optional: set your canonical production origin.
# Defaults to https://go-daily.vercel.app when unset.
# NEXT_PUBLIC_SITE_URL=https://example.com

# Rate limit config (optional, defaults to 60s window / 10 req max)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=10
