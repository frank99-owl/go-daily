# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code session files
.claude/

# generated audit artifacts
/reports/puzzle-audit/*.json
/reports/puzzle-audit/*.md
!/reports/puzzle-audit/.gitkeep
/reports/content-queue/*.json
/reports/content-queue/*.md
!/reports/content-queue/.gitkeep
